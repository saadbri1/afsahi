# ─────────────────────────────────────────────────────────────────────────────
# AFSAHI — environment template. Copy to `.env` and fill in real values.
#   cp .env.example .env
#
# The booking map runs on FREE, key-less services (OpenStreetMap + Nominatim +
# OSRM) — no Google Maps, no API key, no billing, no cloud configuration.
# ─────────────────────────────────────────────────────────────────────────────

# AFSAHI business WhatsApp — international format, digits only, no leading +
VITE_WHATSAPP_NUMBER=212660682895

# Admin dashboard login (/admin). ⚠️ DEMO ONLY: VITE_* vars are bundled into the
# public JS, so this is not real security — connect Supabase Auth for production.
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=change_this_password
