# AFSAHI deployment environment
# Copy to .env for local development. Never commit the populated .env file.

# Business WhatsApp number: international digits only, without leading +
VITE_WHATSAPP_NUMBER=212000000000

# Supabase publishable browser configuration. Database access is governed by
# the policies in supabase/migrations; never use a service-role key here.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_anon_key
